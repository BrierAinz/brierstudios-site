{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2024": true,
    "worker": true
  },
  "parserOptions": {
    "ecmaVersion": 2024,
    "sourceType": "module"
  },
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "navigator": "readonly",
    "location": "readonly",
    "console": "readonly",
    "fetch": "readonly",
    "URL": "readonly",
    "URLSearchParams": "readonly",
    "Blob": "readonly",
    "FormData": "readonly",
    "Headers": "readonly",
    "Request": "readonly",
    "Response": "readonly",
    "crypto": "readonly",
    "sessionStorage": "readonly",
    "localStorage": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "setInterval": "readonly",
    "clearInterval": "readonly",
    "Image": "readonly",
    "TextEncoder": "readonly",
    "TextDecoder": "readonly",
    "URLSearchParams": "readonly",
    "customElements": "readonly",
    "matchMedia": "readonly",
    "AudioContext": "readonly",
    "webkitAudioContext": "readonly",
    "WebAssembly": "readonly",
    "performance": "readonly",
    "addEventListener": "readonly",
    "removeEventListener": "readonly",
    "alert": "readonly",
    "confirm": "readonly",
    "prompt": "readonly",
    "event": "readonly",
    "Swiper": "readonly",
    "gsap": "readonly",
    "IntersectionObserver": "readonly",
    "MutationObserver": "readonly",
    "PerformanceObserver": "readonly",
    "Promise": "readonly",
    "Map": "readonly",
    "Set": "readonly",
    "parseInt": "readonly",
    "parseFloat": "readonly",
    "Math": "readonly",
    "Date": "readonly",
    "Number": "readonly",
    "JSON": "readonly",
    "Object": "readonly",
    "Array": "readonly",
    "String": "readonly",
    "Boolean": "readonly",
    "Error": "readonly",
    "TypeError": "readonly",
    "SyntaxError": "readonly",
    "RangeError": "readonly",
    "encodeURIComponent": "readonly",
    "decodeURIComponent": "readonly",
    "setCurrentToken": "readonly",
    "save": "readonly",
    "loadFn": "readonly",
    "deleteFn": "readonly",
    "escAttr": "readonly",
    "renderFn": "readonly",
    "renderMessages": "readonly",
    "showLoginErr": "readonly",
    "loadMessages": "readonly",
    "doLogin": "readonly",
    "doLogout": "readonly",
    "loadVitals": "readonly",
    "getInputValue": "readonly",
    "rate": "readonly",
    "fmt": "readonly",
    "statusEl": "readonly",
    "msgId": "readonly",
    "msg": "readonly",
    "event": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-implicit-globals": "off",
    "prefer-const": "warn",
    "no-var": "error",
    "eqeqeq": ["error", "smart"],
    "no-console": "off",
    "no-debugger": "warn"
  },
  "overrides": [
    {
      "files": ["tests/**/*.mjs", "scripts/**/*.mjs"],
      "env": { "node": true },
      "parserOptions": { "sourceType": "module" }
    },
    {
      "files": ["*.html"],
      "parserOptions": { "sourceType": "module" },
      "rules": { "no-undef": "off" }
    }
  ]
}